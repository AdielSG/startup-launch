# ── REQUIRED — the server will not start without these ────────────────────────

# Twitter / X API v2 Bearer Token
# Get from: https://developer.x.com → Projects & Apps → Keys and Tokens
TWITTER_BEARER_TOKEN=

# Apify API token — used to scrape LinkedIn post engagement via actor Wpp1BZ6yGWjySadk3
# Get from: https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# OpenAI API key — used to generate personalised outreach DMs (gpt-4o-mini)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=


# ── OPTIONAL — warnings shown at startup if missing ───────────────────────────

# Crunchbase Basic API key — enriches funding totals beyond the $500K YC fallback
# Without this, all companies show $500K (the standard YC deal amount)
# Get from: https://data.crunchbase.com/docs/getting-started
CRUNCHBASE_API_KEY=


# ── Infrastructure (defaults work for local dev) ──────────────────────────────

# SQLite file path (relative to backend/ directory)
DATABASE_URL=sqlite:///./launches.db

# Frontend API base URL — override when deploying outside localhost
# When running locally, the Vite proxy handles /api → :8000 (no change needed)
VITE_API_URL=http://localhost:8000
